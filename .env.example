# PaperCoach runtime config
PAPERCOACH_HOST=127.0.0.1
PAPERCOACH_PORT=8000
PAPERCOACH_DATA_DIR=data

# LLM provider: local | deepseek | openai
PAPERCOACH_LLM_PROVIDER=deepseek

# DeepSeek official OpenAI-compatible API config.
# Do not commit real keys.
PAPERCOACH_DEEPSEEK_API_KEY=sk-your-key-here
PAPERCOACH_DEEPSEEK_BASE_URL=https://api.deepseek.com
PAPERCOACH_DEEPSEEK_MODEL=deepseek-v4-flash

# Optional OpenAI-compatible fallback.
PAPERCOACH_OPENAI_API_KEY=
PAPERCOACH_OPENAI_BASE_URL=https://api.openai.com/v1
PAPERCOACH_OPENAI_MODEL=gpt-4.1-mini
